# ─── IBKR ─────────────────────────────────────────────────────────────────────
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# paper | live
TRADING_MODE=paper

# In sviluppo locale: 127.0.0.1
# In Docker Compose: nome del servizio (ib-gateway)
IBKR_HOST=127.0.0.1

# 4001 = paper, 4002 = live
IBKR_PORT=4001

IBKR_CLIENT_ID=1
IBKR_ACCOUNT=U1234567

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# In sviluppo locale: postgres:5432 → localhost:5432
# In Docker Compose: nome servizio postgres
DATABASE_URL=postgresql+asyncpg://trader:changeme@localhost:5432/trading
POSTGRES_PASSWORD=changeme

# ─── TELEGRAM ─────────────────────────────────────────────────────────────────
# Lasciare vuoti per disabilitare le notifiche (il bot parte lo stesso)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── TAX REPORTING ────────────────────────────────────────────────────────────
# Token e query ID del Flex Web Service IBKR (ottenibili da Account Management)
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ─── RISK LIMITS ──────────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=10000.0
MAX_DAILY_LOSS_USD=500.0
MAX_OPEN_POSITIONS=5
DEFAULT_STOP_LOSS_PCT=0.02

# ─── MONITORING ───────────────────────────────────────────────────────────────
# Accesso VNC all'IB Gateway (debug)
VNC_PASSWORD=changeme
GRAFANA_PASSWORD=admin
